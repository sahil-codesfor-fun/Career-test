generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Student {
  id         Int      @id @default(autoincrement())
  name       String
  email      String
  mobile     String
  gender     String
  state      String
  district   String
  city       String
  school     String
  dob        String
  fatherName String
  motherName String
  address    String
  createdAt  DateTime @default(now())

  results    Result[]
}

model Test {
  id              Int        @id @default(autoincrement())
  title           String
  description     String?
  pdfTemplatePath String?
  createdAt       DateTime   @default(now())

  questions       Question[]
  results         Result[]
}

model Question {
  id        Int      @id @default(autoincrement())
  testId    Int
  test      Test     @relation(fields: [testId], references: [id])
  text      String
  options   Json     // Storing options as JSON array [{"text": "A", "weight": 1}, ...]
  createdAt DateTime @default(now())
}

model Result {
  id        Int      @id @default(autoincrement())
  studentId Int
  student   Student  @relation(fields: [studentId], references: [id])
  testId    Int
  test      Test     @relation(fields: [testId], references: [id])
  score     Int
  outcome   String
  createdAt DateTime @default(now())
}

model CounsellingRequest {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  mobile    String
  createdAt DateTime @default(now())
}
